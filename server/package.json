{
  "name": "recluster-server",
  "version": "0.1.0",
  "private": true,
  "description": "reCluster server",
  "homepage": "https://github.com/carlocorradini/reCluster#readme",
  "bugs": {
    "url": "https://github.com/carlocorradini/reCluster/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/carlocorradini/reCluster.git",
    "directory": "server"
  },
  "license": "MIT",
  "author": "Carlo Corradini <carlo.corradini98@gmail.com>",
  "scripts": {
    "build": "npx tsc --build tsconfig.json",
    "build:clean": "npx tsc --build --clean tsconfig.json",
    "build:watch": "npx tsc --build --watch tsconfig.json",
    "check": "npx npm-run-all --npm-path npm --serial check:*",
    "check:db": "npm run db:format",
    "check:lint": "npx eslint .",
    "dev": "./scripts/dev.sh --k3d-config-file ./k3d.config.yaml",
    "db:deploy": "npx prisma migrate deploy",
    "db:format": "npx prisma format",
    "db:generate": "npx prisma generate",
    "db:reset": "npx prisma migrate reset",
    "db:seed": "npx prisma db seed",
    "db:studio": "npx prisma studio",
    "db:sync": "npx prisma migrate dev --name recluster",
    "dockerize": "./scripts/dockerize.sh",
    "fix": "npx npm-run-all --npm-path npm --serial fix:*",
    "fix:db": "npm run db:format",
    "fix:lint": "npx eslint --fix .",
    "graphql:schema": "npx ts-node ./scripts/schema.ts | npx pino-pretty --translateTime \"UTC:yyyy-mm-dd'T'HH:MM:ss'Z'\"",
    "prepare": "npx ts-patch install -s && npm run db:generate",
    "start": "node build/main.js",
    "start:dev": "npx ts-node-dev --respawn --clear --rs --transpile-only --tree-kill --exit-child --require tsconfig-paths/register src/main.ts | npx pino-pretty --translateTime \"UTC:yyyy-mm-dd'T'HH:MM:ss'Z'\""
  },
  "dependencies": {
    "@apollo/server": "^5.4.0",
    "@as-integrations/fastify": "^3.1.0",
    "@fastify/compress": "^8.3.0",
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.1",
    "@fastify/rate-limit": "^10.3.0",
    "@graphql-tools/schema": "^10.0.31",
    "@graphql-tools/utils": "^10.11.0",
    "@kubernetes/client-node": "^1.4.0",
    "@prisma/client": "^7.5.0",
    "axios": "^1.13.6",
    "bcryptjs": "^3.0.3",
    "class-validator": "^0.15.1",
    "convert": "^7.0.0",
    "dotenv": "^17.3.1",
    "envalid": "^8.1.1",
    "fastify": "^5.8.4",
    "fastify-healthcheck": "^5.1.0",
    "graphql": "^16.13.1",
    "graphql-scalars": "^1.25.0",
    "json-bigint-patch": "^0.0.9",
    "jsonwebtoken": "^9.0.3",
    "node-ssh": "^13.2.1",
    "pino": "^10.3.1",
    "prisma": "^7.5.0",
    "reflect-metadata": "^0.2.2",
    "tsyringe": "^4.10.0",
    "type-graphql": "^2.0.0-rc.3",
    "wake_on_lan": "^1.0.0"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.10",
    "@types/ssh2": "^1.15.5",
    "@types/wake_on_lan": "^0.0.33",
    "@types/yargs": "^17.0.35",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "eslint": "^9.39.4",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-config-airbnb-typescript": "^18.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-license-header": "^0.6.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-tsdoc": "^0.5.2",
    "pino-pretty": "^13.1.3",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "ts-patch": "^3.3.0",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3",
    "typescript-transform-paths": "^3.5.6",
    "yargs": "^18.0.0"
  },
  "engines": {
    "node": ">=16",
    "npm": ">=8"
  },
  "prisma": {
    "seed": "npx ts-node prisma/seed.ts"
  }
}
